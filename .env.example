# ─────────────────────────────────────────────────────────────────────────────
# Vy Clan War Tracker — Environment Variables
# Copy this file to ".env" and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Discord (only needed for the bot version) ─────────────────────────────────
# Get this from https://discord.com/developers/applications → your app → Bot → Token
DISCORD_TOKEN=PASTE_YOUR_BOT_TOKEN_HERE

# ── Google Sheets ─────────────────────────────────────────────────────────────
# The ID from your sheet URL:
#   https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
SPREADSHEET_ID=PASTE_YOUR_SPREADSHEET_ID_HERE

# Path to your Google Service Account JSON key file (keep it in this folder)
CREDENTIALS_FILE=credentials.json

# ── Clan Settings ─────────────────────────────────────────────────────────────
# Your clan tag exactly as it appears in the Lorenzi/Quaxly output
CLAN_NAME=Vy

# Auto-log any detected Quaxly/Lorenzi result messages in channels the bot can read.
# Set to false if you only want manual logging via !addwar (including reply-to-message flow).
AUTO_LOG_RESULTS=true
